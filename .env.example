# ==============================
# Application
# ==============================
APP_NAME=TaskFlow Analytics
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ==============================
# Security
# WARNING: Replace all secrets before deploying.
# ==============================
SECRET_KEY=replace-with-a-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ==============================
# Database
# Default local dev fallback:
# DATABASE_URL=sqlite:///./taskflow.db
# ==============================
DATABASE_URL=postgresql://taskflow:taskflow@localhost:5432/taskflow_dev
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# ==============================
# Redis
# ==============================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ==============================
# CORS
# JSON-style list expected by Pydantic settings
# ==============================
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ==============================
# Rate Limiting
# ==============================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ==============================
# Email
# ==============================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=[your-email]
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM=[your-email]
SMTP_USE_TLS=true

# ==============================
# Monitoring
# ==============================
SENTRY_DSN=
METRICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=90
PROMETHEUS_ENABLED=false
