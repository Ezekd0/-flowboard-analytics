# ==============================
# Application
# ==============================
APP_NAME=TaskFlow Analytics
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING

# ==============================
# Security
# WARNING: Use a secret manager in production.
# ==============================
SECRET_KEY=replace-with-64-char-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14
BCRYPT_ROUNDS=14

# ==============================
# Database
# ==============================
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql://taskflow:replace-with-strong-db-password@db:5432/taskflow_prod
DATABASE_POOL_SIZE=30
DATABASE_MAX_OVERFLOW=60
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=900

# ==============================
# Redis
# ==============================
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_URL=redis://:replace-with-strong-redis-password@redis:6379/0

# ==============================
# CORS
# ==============================
BACKEND_CORS_ORIGINS=["https://[your-domain.com]"]

# ==============================
# Rate Limiting
# ==============================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ==============================
# Monitoring and Logging
# ==============================
SENTRY_DSN=https://[key]@[host]/[project-id]
METRICS_ENABLED=true
PROMETHEUS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.[your-domain.com]
JSON_LOGS=true

# ==============================
# Backup
# ==============================
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=14
BACKUP_STORAGE_PATH=/backups
